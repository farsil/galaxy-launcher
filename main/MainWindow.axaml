<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loader="clr-namespace:DosboxLauncher.Loader"
        xmlns:main="clr-namespace:DosboxLauncher.Main"
        mc:Ignorable="d"
        d:DesignWidth="1024"
        d:DesignHeight="768"
        x:Class="DosboxLauncher.Main.MainWindow"
        x:DataType="main:MainWindowViewModel"
        Title="Dosbox Launcher">
    <DockPanel Margin="0 16 0 0">
        <TextBox DockPanel.Dock="Top"
                 Width="256"
                 Watermark="Search..."
                 Text="{Binding SearchText, Mode=TwoWay}" />
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0 24 0 0">
            <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding FilteredPrograms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="loader:Program">
                        <main:ProgramCard Title="{Binding Title}"
                                          ImagePath="{Binding CardPath}" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>