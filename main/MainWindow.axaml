<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loader="clr-namespace:DosboxLauncher.Loader"
        xmlns:main="clr-namespace:DosboxLauncher.Main"
        mc:Ignorable="d"
        d:DesignWidth="1024"
        d:DesignHeight="768"
        x:Class="DosboxLauncher.Main.MainWindow"
        x:DataType="main:MainWindowViewModel"
        Title="Dosbox Launcher">
    <Window.Resources>
        <main:PathToImageConverter x:Key="PathToImageConverter" />
    </Window.Resources>
    <DockPanel Margin="0 16 0 0">
        <TextBox DockPanel.Dock="Top"
                 Width="256"
                 Watermark="Search..."
                 Text="{Binding SearchText, Mode=TwoWay}" />
        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0 24 0 0">
            <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding FilteredPrograms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="loader:Program">
                        <StackPanel
                            Spacing="16"
                            Width="256">
                            <!-- The default size of GOG cards is 342x482 -->
                            <main:RoundedImage
                                Radius="12"
                                MaxWidth="228"
                                MaxHeight="321"
                                Source="{Binding CardPath,
                                                 Converter={StaticResource PathToImageConverter},
                                                 FallbackValue={StaticResource CardFallbackImage},
                                                 TargetNullValue={StaticResource CardFallbackImage}}" />
                            <TextBlock Text="{Binding Title}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>