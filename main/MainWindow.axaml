<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loader="clr-namespace:DosboxLauncher.Loader"
        xmlns:main="clr-namespace:DosboxLauncher.Main"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="DosboxLauncher.Main.MainWindow"
        x:DataType="main:MainWindowViewModel"
        Title="Dosbox Launcher">
    <StackPanel>
        <TextBox Width="240"
                 HorizontalAlignment="Center"
                 Watermark="Search..."
                 Text="{Binding SearchText, Mode=TwoWay}" />
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding FilteredPrograms}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel ItemWidth="250" ItemHeight="110" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="loader:Program">
                        <Border Margin="8"
                                Padding="12"
                                CornerRadius="8"
                                Background="{DynamicResource ThemeControlLowBrush}">
                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Path}"
                                           FontSize="12"
                                           Opacity="0.7"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding ConfigPath}"
                                           FontSize="12"
                                           Opacity="0.7"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </StackPanel>
</Window>