<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="DosboxLauncher.Main.SyntheticTitlebar"
             IsVisible="False">
    <UserControl.Styles>
        <Style Selector="Button:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="TextBlock.Foreground"
                    Value="{DynamicResource SystemBaseMediumHighColor}" />
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style Selector="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="TextBlock.Foreground"
                    Value="{DynamicResource SystemBaseMediumLowColor}" />
        </Style>
    </UserControl.Styles>

    <StackPanel Margin="0 8 8 0"
                Height="32"
                Spacing="4"
                Orientation="Horizontal"
                HorizontalAlignment="Right">
        <Button Content="🗕"
                Padding="0 0 0 4"
                Click="OnMinimizeButtonClick"
                x:Name="MinimizeButton" />
        <Button Content="🗖"
                Padding="0 0 0 2"
                Click="OnMaximizeToggleButtonClick"
                x:Name="MaximizeToggleButton" />
        <Button Content="✕"
                Padding="0"
                Click="OnCloseButtonClick"
                x:Name="CloseButton" />
    </StackPanel>
</UserControl>