<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:main="clr-namespace:GalaxyLauncher.Main"
             x:Class="GalaxyLauncher.Main.ProgramCard"
             x:DataType="main:ProgramCardViewModel">
    <UserControl.Styles>
        <Style Selector="Button:focus /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentButtonBackground}" />
        </Style>
        <Style Selector="Button:pressed /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentButtonBackgroundPressed}" />
        </Style>
        <Style Selector="Button:disabled /template/ ContentPresenter">
            <Setter Property="Background" Value="Transparent" />
        </Style>
    </UserControl.Styles>

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://GalaxyLauncher/Main/FallbackCardImage.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <main:PathToImageConverter x:Key="PathToImageConverter" />
        </ResourceDictionary>
    </UserControl.Resources>

    <Button Padding="16"
            CornerRadius="12"
            VerticalAlignment="Top"
            Background="Transparent"
            FocusAdorner="{x:Null}"
            IsEnabled="{Binding CanStart}"
            Command="{Binding StartCommand}"
            CommandParameter="{Binding Program}"
            x:Name="Button">
        <Button.KeyBindings>
            <KeyBinding Gesture="Enter"
                        Command="{Binding StartCommand}"
                        CommandParameter="{Binding Program}" />
        </Button.KeyBindings>
        <StackPanel Spacing="16" Width="171">
            <!-- The default size of GOG cards is 342x482 -->
            <main:RoundedImage Radius="12"
                               MaxWidth="171"
                               MaxHeight="241"
                               IsEnabled="{Binding CanStart}"
                               Source="{Binding Program.ImagePath, 
                                                Converter={StaticResource PathToImageConverter},
                                                FallbackValue={StaticResource FallbackCardImage},
                                                TargetNullValue={StaticResource FallbackCardImage}}" />
            <TextBlock Text="{Binding Program.Title}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       TextAlignment="Center" />
        </StackPanel>
    </Button>
</UserControl>