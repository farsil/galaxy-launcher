<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:main="clr-namespace:GalaxyLauncher.Main"
        x:Class="GalaxyLauncher.Main.MainWindow"
        x:DataType="main:MainWindowViewModel"
        Title="Galaxy Launcher"
        Width="1024"
        MinWidth="740"
        Height="768"
        MinHeight="400"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://GalaxyLauncher/Main/QuestionMarkImage.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <DockPanel>
        <main:SyntheticTitlebar DockPanel.Dock="Top" />
        <StackPanel DockPanel.Dock="Bottom"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="12"
                    Margin="24"
                    Height="32">
            <TextBox TabIndex="1"
                     Width="256"
                     Watermark="Search..."
                     Text="{Binding SearchText, Mode=TwoWay}" />
            <main:StopButton TabIndex="2"
                             IsEnabled="{Binding DosboxState.IsActive}"
                             Command="{Binding StopDosboxCommand}" />
            <TextBlock HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       IsVisible="{Binding !DosboxState.IsRunnable}"
                       Foreground="{DynamicResource DangerousColor}"
                       FontWeight="SemiBold">
                Unable to find DOSBox executable!
            </TextBlock>
        </StackPanel>
        <Panel>
            <StackPanel VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="24"
                        IsVisible="{Binding !SearchResults.Count}">
                <Image Height="120"
                       Width="120"
                       Source="{DynamicResource QuestionMarkImage}" />
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemBaseMediumColor}"
                           TextAlignment="Center">
                    No programs found
                </TextBlock>
            </StackPanel>
            <ScrollViewer XYFocus.NavigationModes="Enabled"
                          VerticalScrollBarVisibility="Auto"
                          IsVisible="{Binding SearchResults.Count}">
                <ItemsControl HorizontalAlignment="Center" ItemsSource="{Binding SearchResults}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel KeyboardNavigation.TabNavigation="Once"
                                       TabIndex="0"
                                       Margin="24 16"
                                       LineSpacing="32"
                                       ItemSpacing="32" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <main:ProgramCard DataContext="{Binding .}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</Window>